{
  "signal": {
    "sampling_rate_hz": 1000,
    "duration_seconds": 10,
    "frequencies_hz": [5, 50, 150, 450],
    "noise": {
      "sigma": 0.1,
      "sigma_2": 0.05
    }
  },
  "data": {
    "window_size": 10,
    "train_split": 0.8,
    "val_split": 0.1,
    "test_split": 0.1
  },
  "models": {
    "mlp": {
      "layers": [128, 256, 128],
      "activation": "relu",
      "dropout": 0.1
    },
    "rnn": {
      "num_layers": 2,
      "hidden_units": 128,
      "dropout": 0.1,
      "state_formula": "y = f_w(x) + memory"
    },
    "lstm": {
      "num_layers": 2,
      "hidden_units": 256,
      "dropout": 0.1,
      "state_formula": "y = f_w(x) + memory"
    }
  },
  "training": {
    "batch_size": 64,
    "epochs": 100,
    "learning_rate": 0.001,
    "patience": 10
  }
}
