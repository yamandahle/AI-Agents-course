# Article Writer — Environment Variables
# Copy this file to .env and fill in your actual API keys.
# NEVER commit the .env file to git.

# ── LLM Provider Selection ───────────────────────────────────────────────────
# Set to "anthropic" to use Claude Sonnet, or "google" to use Gemini as writer.
# Research tools always use Gemini + Perplexity regardless of this setting.
LLM_PROVIDER=anthropic

# ── Anthropic Claude ─────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic.
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=google OR as the research search backend.
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Perplexity ────────────────────────────────────────────────────────────────
# Fallback research backend. Get your key at https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here
